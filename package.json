{
  "name": "ajaw-data-migration",
  "version": "0.1.0",
  "private": true,
  "description": "Field mapping registry and migration tooling for Leads DB -> Axelor",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "migrate": "tsx src/cli/bootstrap.ts migrate",
    "seed": "tsx src/cli/bootstrap.ts seed",
    "refresh": "tsx src/cli/bootstrap.ts refresh-catalog && tsx src/cli/bootstrap.ts sample --refresh",
    "migrate:run": "tsx src/cli/migrate.ts run",
    "dev:api": "tsx src/api/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
